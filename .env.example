# =============================================================
# Carnavei — Loja Virtual · variáveis de ambiente
# Copie para .env e preencha. Os valores reais ficam no cofre
# compartilhado (Bitwarden/1Password) ou na Vercel (vercel env pull).
# NUNCA commite o .env preenchido.
# =============================================================

# --- Banco de dados (Neon) ---
DATABASE_URL=
DIRECT_URL=

# --- Autenticação (NextAuth) ---
# Gere com: openssl rand -base64 32
AUTH_SECRET=
SESSION_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Pagamento (Mercado Pago) ---
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
NEXT_PUBLIC_MP_PUBLIC_KEY=
MP_TEST_BUYER_EMAIL=

# --- Frete (Melhor Envio) ---
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_FROM_CEP=
MELHOR_ENVIO_ENV=sandbox

# --- E-mail (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
EMAIL_FROM=
ADMIN_EMAIL=
ADMIN_NOTIFICATION_EMAILS=

# --- OAuth providers ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
